{
  "crons": [
    {
      "path": "/api/generate-signals",
      "schedule": "*/3 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,x-vercel-cron" }
      ]
    }
  ]
}
